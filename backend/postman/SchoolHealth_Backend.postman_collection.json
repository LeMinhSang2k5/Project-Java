{
  "info": {
    "_postman_id": "6c49ab6f-4fd4-41ab-9b4a-c5c78d2703cb",
    "name": "School Health Backend Auto Tests",
    "description": "Auto-test collection for the Spring Boot school health backend. Import with the local environment, start the backend on port 8080, then run read-only folders first. Requests in Mutation Samples can change the local database.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const expectedStatusCodes = [200, 201, 204, 400, 401, 404];",
          "",
          "pm.test('status code is expected for this API suite', function () {",
          "  pm.expect(expectedStatusCodes, 'Unexpected status: ' + pm.response.code).to.include(pm.response.code);",
          "});",
          "",
          "pm.test('response time is under 2000ms', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "pm.test('JSON response is valid when body looks like JSON', function () {",
          "  const body = pm.response.text().trim();",
          "  if (!body || pm.response.code === 204) return;",
          "  if (body.startsWith('{') || body.startsWith('[')) {",
          "    pm.expect(function () { pm.response.json(); }).not.to.throw();",
          "  }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returns success or unauthorized for seeded password style', function () {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.test('login response has user identity fields', function () {",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('email');",
                  "    pm.expect(json).to.have.property('fullName');",
                  "    pm.expect(json).to.have.property('role');",
                  "  });",
                  "  pm.environment.set('userId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
